<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · فرص خضراء</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
    <div class="shell">
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-mark">ف</span>
                <div class="brand-text">
                    <strong>فرص خضراء</strong>
                    <span>لوحة الفريق</span>
                </div>
            </div>

            <nav class="nav">
                <a class="nav-link @(ViewData["Active"]?.ToString() == "dashboard" ? "is-active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <span class="nav-icon">▤</span> لوحة التحليلات
                </a>
                <a class="nav-link @(ViewData["Active"]?.ToString() == "chat" ? "is-active" : "")"
                   asp-controller="Home" asp-action="Chat">
                    <span class="nav-icon">✦</span> المساعد الذكي
                </a>
            </nav>

            <div class="sidebar-foot">
                <span class="dot"></span> البيانات محمّلة محليًا
            </div>
        </aside>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
